{
  "profile": "full",
  "_profile_note": "economy / dev / full / custom 중 하나. UI 의 '프로필 프리셋' 버튼으로 전환하거나, 각 섹션의 enabled 플래그를 개별 토글해 custom 으로 만들 수 있음.",
  "naver_news": {
    "ranking": {
      "enabled": true,
      "_note": "'많이 본 뉴스' 기반이라 연예·사회 기사가 섞일 수 있음. 기본 비활성, keyword_search 가 경제 기사 공급 담당.",
      "press_whitelist": [
