{
  "profile": "full",
  "_profile_note": "economy / dev / full / custom 중 하나. UI 의 '프로필 프리셋' 버튼으로 전환하거나, 각 섹션의 enabled 플래그를 개별 토글해 custom 으로 만들 수 있음.",
  "naver_news": {
    "ranking": {
      "enabled": true,
      "_note": "'많이 본 뉴스' 기반이라 연예·사회 기사가 섞일 수 있음. 기본 비활성, keyword_search 가 경제 기사 공급 담당.",
      "press_whitelist": [
        "매일경제",
        "한국경제",
        "머니투데이",
        "이데일리",
        "파이낸셜뉴스",
        "조선비즈",
        "아시아경제",
        "서울경제",
        "헤럴드경제"
      ],
      "top_n": 10
    },
    "keyword_search": {
      "enabled": false,
      "_note": "네이버 오픈 API 뉴스 검색. 키워드별 최신 pubDate 기준 per_keyword 건 수집 후 window 필터. 일 21회 호출 (7키워드 × 3), 쿼터 25,000/일 대비 여유.",
      "keywords": [
        {
          "term": "금리",
          "category": "거시"
        },
        {
          "term": "환율",
          "category": "거시"
        },
        {
          "term": "물가",
          "category": "거시"
        },
        {
          "term": "부동산",
          "category": "자산"
        },
        {
          "term": "코스피",
          "category": "자산"
        },
        {
          "term": "연준",
          "category": "글로벌"
        },
        {
          "term": "나스닥",
          "category": "글로벌"
        }
      ],
      "per_keyword": 5,
      "sort": "date"
    }
  },
  "dev_news": {
    "enabled": true,
    "sources": [
      {
        "name": "OpenAI",
        "type": "rss",
        "url": "https://openai.com/news/rss.xml"
      },
      {
        "name": "Anthropic",
        "type": "html_scrape",
        "url": "https://www.anthropic.com/news",
        "_note": "공식 RSS 없음 → HTML 파싱 (BeautifulSoup). 선택자는 collect_anthropic.py 에서 관리."
      }
    ]
  },
  "threads": {
    "enabled": true,
    "accounts": [
      {
        "handle": "swyx",
        "label": "AI 엔지니어링"
      },
      {
        "handle": "yoheinakajima",
        "label": "에이전트 연구"
      },
      {
        "handle": "karpathy",
        "label": "ML 대가"
      },
      {
        "handle": "tatum_hq",
        "label": "바이브코딩 보안"
      }
    ],
    "max_posts_per_account": 5,
    "fetch_method": "rsshub",
    "rsshub_base": "https://rsshub.app"
  },
  "schedule": {
    "time_kst": "08:00",
    "cron_utc": "0 23 * * *",
    "_note": "time_kst 변경 시 cron_utc 자동 재계산. GitHub Actions 워크플로 YAML 이 저장 시 함께 동기화됨."
  },
  "window": {
    "timezone": "Asia/Seoul",
    "_note": "수집 시간창은 schedule.time_kst 기준 직전 24시간. 랭킹은 미적용 (인기 순 자체가 최근성 반영).",
    "applies_to": [
      "keyword_search",
      "dev_news",
      "threads"
    ]
  },
  "output": {
    "obsidian": {
      "daily_note_path": "Daily/{date}.md",
      "include_raw_lead": true
    },
    "channels": {
      "telegram": {
        "enabled": true,
        "split_by_section": true,
        "_env_required": [
          "TELEGRAM_BOT_TOKEN",
          "TELEGRAM_CHAT_ID"
        ]
      },
      "slack": {
        "enabled": false,
        "split_by_section": true,
        "_env_required": [
          "SLACK_WEBHOOK_URL"
        ]
      }
    }
  },
  "dedupe": {
    "retention_days": 30
  },
  "summarize": {
    "model": "gemini-2.5-flash",
    "_note": "Google Gemini 모델 ID. 2.5-flash 가 무료 티어 호환성 가장 좋음. 다른 옵션: gemini-2.5-pro (고품질), gemini-2.0-flash (계정에 따라 quota:0 일 수 있음). aistudio.google.com/apikey 에서 발급."
  }
}
