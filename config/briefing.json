  "threads": {
    "enabled": false,
    "_note": "RSSHub 공용 인스턴스(rsshub.app) 가 2026-04 부로 production 접근 차단(HTTP 403). Self-host 하기 전에는 동작 불가. 대신 개인 블로그 RSS (Simon Willison, Karpathy bearblog, Latent Space 등) 를 dev_news.sources 에 추가해 커버.",
    "accounts": [
      { "handle": "swyx",          "label": "AI 엔지니어링" },
      { "handle": "yoheinakajima", "label": "에이전트 연구" },
      { "handle": "karpathy",      "label": "ML 대가" },
      { "handle": "simonw",        "label": "LLM 도구·프롬프트 엔지니어링" },
      { "handle": "sama",          "label": "OpenAI CEO" },
      { "handle": "levie",         "label": "Box CEO · 엔터프라이즈 AI 관점" },
      { "handle": "alexandr_wang", "label": "Scale AI · AGI 담론" },
      { "handle": "goodside",      "label": "프롬프트 엔지니어링 선구자" }
    ],
    "max_posts_per_account": 5,
    "fetch_method": "rsshub",
    "rsshub_base": "https://rsshub.app"
